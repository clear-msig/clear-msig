NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8080
# Ramp service (NGN ↔ crypto). Runs as a sidecar — separate Fly app
# in production. Defaults to localhost for dev.
NEXT_PUBLIC_RAMP_API_URL=http://127.0.0.1:8088
NEXT_PUBLIC_DEFAULT_WALLET_NAME=treasury

# Dynamic embedded-wallet — sign up at app.dynamic.xyz, copy the
# environment ID from your project settings. Only used by the
# /spike/dynamic page today; rest of the app still uses the
# wallet-adapter stack until the migration lands.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Ika pre-alpha defaults (frontend prefill only; can still be overridden in UI)
NEXT_PUBLIC_IKA_CHAIN=evm_1559
NEXT_PUBLIC_IKA_DWALLET_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
NEXT_PUBLIC_IKA_GRPC_URL=https://pre-alpha-dev-1.ika.ika-network.net:443
NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_DESTINATION_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=https://hyperliquid-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Email invite delivery (server-side Next API route)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASS=your-password
SMTP_FROM="Clear-MSIG <noreply@example.com>"

# Natural-language send parser. Powers the "just say it" input on
# /send. Without this set, the API route returns 503 and the
# frontend silently leaves the field unrendered. Get a key at
# console.anthropic.com.
ANTHROPIC_API_KEY=

# Upstash Redis (REST) for shared-state rate limiting across Vercel
# function instances. Both vars must be set to enable; missing either
# falls back to per-instance in-process limits. See SECURITY.md surface E.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
