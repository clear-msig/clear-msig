NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8080
# Ramp service (NGN ↔ crypto). Runs as a sidecar — separate Fly app
# in production. Defaults to localhost for dev.
NEXT_PUBLIC_RAMP_API_URL=http://127.0.0.1:8088
NEXT_PUBLIC_DEFAULT_WALLET_NAME=treasury

# Dynamic embedded-wallet — sign up at app.dynamic.xyz, copy the
# environment ID from your project settings. Only used by the
# /spike/dynamic page today; rest of the app still uses the
# wallet-adapter stack until the migration lands.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Ika pre-alpha defaults (frontend prefill only; can still be overridden in UI)
NEXT_PUBLIC_IKA_CHAIN=evm_1559
NEXT_PUBLIC_IKA_DWALLET_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
NEXT_PUBLIC_IKA_GRPC_URL=https://pre-alpha-dev-1.ika.ika-network.net:443
NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_DESTINATION_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_HYPERLIQUID_RPC_URL=https://hyperliquid-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_BITCOIN_TESTNET_RPC_URL=https://bitcoin-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_BITCOIN_SIGNET_RPC_URL=https://bitcoin-signet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Pro treasury runtime knobs (public, non-secret). These keep the
# B2B operating layer configurable across devnet/staging/production
# without hardcoding product policy into components.
NEXT_PUBLIC_CLEARSIG_ENVIRONMENT_LABEL=Devnet
NEXT_PUBLIC_CLEARSIG_PRO_DEFAULT_PAYMENT_ASSET=SOL
NEXT_PUBLIC_CLEARSIG_PRO_BATCH_CSV_COLUMNS=name,address,asset,amount,note
NEXT_PUBLIC_CLEARSIG_PRO_IMPORT_SOURCES=Squads,Safe,CSV
NEXT_PUBLIC_CLEARSIG_PRO_ACCOUNTING_TARGETS=CSV,QuickBooks,Xero
NEXT_PUBLIC_CLEARSIG_STATUS_URL=/security
NEXT_PUBLIC_CLEARSIG_AUDIT_URL=/app/security-architecture
NEXT_PUBLIC_CLEARSIG_SECURITY_URL=/security
NEXT_PUBLIC_CLEARSIG_RECOVERY_POLICY_URL=/app/secure

# Email invite delivery (server-side Next API route)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASS=your-password
SMTP_FROM="Clear-MSIG <noreply@example.com>"

# Natural-language send parser. Powers the "just say it" input on
# /send. Without this set, the API route returns 503 and the
# frontend silently leaves the field unrendered. Get a key at
# console.anthropic.com.
ANTHROPIC_API_KEY=

# Upstash Redis (REST) for shared rate limits, durable agent state, and
# authenticated cross-device notifications. Production agent/notification
# writes fail closed when either value is missing; local development uses
# process memory. See SECURITY.md surface E.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Hyperliquid practice trading. These stay on the ClearSig server.
# 1. Copy this from the main Hyperliquid practice account that owns the funds,
# open positions, and PnL. Use the main account address, not the API wallet address.
CLEARSIG_HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS=
# 2. Use the helper address. Local default:
CLEARSIG_HYPERLIQUID_TESTNET_EXECUTOR_URL=http://127.0.0.1:4010
# 3. Create this yourself with:
# python3 ../examples/hyperliquid-testnet-executor/generate_token.py
# It must match CLEARSIG_EXECUTOR_TOKEN in the helper's ignored .env file.
CLEARSIG_HYPERLIQUID_TESTNET_EXECUTOR_TOKEN=
