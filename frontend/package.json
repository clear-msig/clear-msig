{
  "name": "clear-msig-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run check:intents && npm run check:architecture && npm run lint && npm run typecheck && npm test && npm run build:webpack && npm run check:bundles",
    "build:webpack": "NODE_OPTIONS=\"--max-old-space-size=4096 --dns-result-order=ipv4first\" next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:clean": "tsc --noEmit --incremental false",
    "check:intents": "node scripts/check-intent-registry.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:bundles": "node scripts/check-bundle-budgets.mjs",
    "profile:bundles": "CLEARSIG_BUNDLE_PROFILE=1 npm run build:webpack && node scripts/profile-sdk-bundles.mjs",
    "report:large-modules": "node scripts/report-large-modules.mjs",
    "verify": "npm run check:intents && npm run check:architecture && npm run lint && npm run typecheck && npm test",
    "test": "vitest run && node --test scripts/*.test.mjs",
    "test:send-matrix": "vitest run src/features/send/infrastructure/sendVerificationMatrix.test.ts src/lib/clearsign/__tests__/remoteSendRoutes.test.ts src/lib/clearsign/__tests__/typedProposalSigningContract.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dynamic-labs/embedded-wallet-solana": "^4.79.0",
    "@dynamic-labs/sdk-react-core": "^4.79.0",
    "@dynamic-labs/solana": "^4.79.0",
    "@dynamic-labs/solana-core": "^4.79.0",
    "@dynamic-labs/waas-svm": "^4.79.0",
    "@encrypt.xyz/pre-alpha-solana-client": "^0.1.1",
    "@ledgerhq/hw-app-solana": "^7.10.1",
    "@ledgerhq/hw-transport-webhid": "^6.35.1",
    "@mysten/bcs": "^2.0.5",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.5.0",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.79.0",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.12.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "nodemailer": "^8.0.7",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "@solana/web3.js": "$@solana/web3.js"
  }
}
