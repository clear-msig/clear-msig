# Backend runtime
CLEAR_MSIG_ENV=development
CLEAR_MSIG_URL=https://solana-devnet.example.invalid
CLEAR_MSIG_PROGRAM_ID=53aZBmukjX5sYxbrYVRDd2DWzsRWVmvVFPY6PcyomR5v
CLEAR_MSIG_ALLOWED_ORIGIN=http://localhost:3000
CLEAR_MSIG_ATTESTATION_DIR=./var/attestations
CLEAR_MSIG_PRO_STORE_PATH=./var/pro-store.json
RUST_LOG=info

# Supply secrets through the deployment platform. Never place real values here.
CLEAR_MSIG_KEYPAIR_BASE64=<base64-encoded-service-keypair>
CLEAR_MSIG_SIGNER_BASE64=<base64-encoded-destination-signer>
UPSTASH_REDIS_REST_URL=https://example.invalid
UPSTASH_REDIS_REST_TOKEN=<redis-rest-token>

# Ika and destination adapters
CLEAR_MSIG_DEFAULT_DWALLET_PROGRAM=<ika-dwallet-program-id>
CLEAR_MSIG_DEFAULT_GRPC_URL=https://ika-grpc.example.invalid
CLEAR_MSIG_DEFAULT_DEST_RPC_URL=https://destination-rpc.example.invalid

# Frontend server/build configuration
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:10000
NEXT_PUBLIC_CLEAR_WALLET_PROGRAM_ID=53aZBmukjX5sYxbrYVRDd2DWzsRWVmvVFPY6PcyomR5v
NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-devnet.example.invalid
