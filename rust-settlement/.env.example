
RAMP_BIND_ADDR=0.0.0.0:8088

# At least one of these is required by the service
DATABASE_URL=
DATABASE_URL_DIRECT=

# Active payment provider: paystack | kora
RAMP_PAYMENT_PROVIDER=paystack

PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx

KORA_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
KORA_BASE_URL=https://api.korapay.com/merchant
KORA_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx

RAMP_WORKER_POLL_INTERVAL_MS=2000

# Signer backend selector (current default)
TREASURY_SIGNER_BACKEND=raw

EVM_RPC_URL=
SUI_RPC_URL=

TREASURY_EVM_PRIVATE_KEY=
TREASURY_SUI_PRIVATE_KEY_BASE64=

TREASURY_EVM_ADDRESS=
TREASURY_SUI_ADDRESS=

# For test rollout keep liquidity check off to avoid RPC flakiness
RAMP_ENABLE_TREASURY_LIQUIDITY_CHECK=false

# Temporary max buy cap: $10.00 (in cents)
RAMP_ONRAMP_MAX_USD_CENTS=1000

# Optional URL used by initialize-payment provider checkout redirect
RAMP_FRONTEND_CALLBACK_URL=
