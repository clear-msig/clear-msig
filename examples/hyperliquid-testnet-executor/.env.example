# 1. Copy this from the Hyperliquid practice account that owns the funds,
# open positions, and PnL. This is public and is safe to paste here.
HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS=0x0000000000000000000000000000000000000000

# 2. Copy this from the separate API wallet that the main account approved.
# Keep the real value only in examples/hyperliquid-testnet-executor/.env.
HYPERLIQUID_TESTNET_API_WALLET_PRIVATE_KEY=0xYOUR_API_WALLET_PRIVATE_KEY

# 3. Create this yourself. It is the private shared password between ClearSig
# and this helper. Hyperliquid does not provide it.
# Generate it with: python3 generate_token.py
# It must match CLEARSIG_HYPERLIQUID_TESTNET_EXECUTOR_TOKEN in frontend/.env.local.
CLEARSIG_EXECUTOR_TOKEN=replace-with-a-long-random-token

# These defaults keep the helper reachable only from this computer.
CLEARSIG_EXECUTOR_HOST=127.0.0.1
CLEARSIG_EXECUTOR_PORT=4010

# Extra helper safety caps. ClearSig also checks rules before reaching here.
CLEARSIG_EXECUTOR_MAX_NOTIONAL_USD=500
CLEARSIG_EXECUTOR_MAX_LEVERAGE=2
CLEARSIG_EXECUTOR_MAX_APPROVAL_AGE_SECONDS=1800
