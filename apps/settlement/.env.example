RAMP_BIND_ADDR=0.0.0.0:8088

# At least one of these is required by the service
DATABASE_URL=
DATABASE_URL_DIRECT=

# ─── Active payment provider ────────────────────────────────────────
# Active payment provider: paystack | kora
RAMP_PAYMENT_PROVIDER=paystack

PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx

KORA_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
KORA_BASE_URL=https://api.korapay.com/merchant
KORA_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxx

RAMP_WORKER_POLL_INTERVAL_MS=2000

# Signer backend selector (current default)
TREASURY_SIGNER_BACKEND=raw

# ─── Solana treasury ────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# Either TREASURY_SOL_KEYPAIR_BASE58 (Phantom-export style, 64 bytes
# base58) or TREASURY_SOL_KEYPAIR_PATH (solana-keygen JSON file) must
# be set. The signer prefers the base58 form.
TREASURY_SOL_KEYPAIR_BASE58=
TREASURY_SOL_KEYPAIR_PATH=
# Optional — will be derived from the keypair if left empty.
TREASURY_SOL_ADDRESS=

# ─── EVM treasury (Ethereum + L2s) ─────────────────────────────────
EVM_RPC_URL=
TREASURY_EVM_PRIVATE_KEY=
TREASURY_EVM_ADDRESS=

# ─── Bitcoin treasury (P2WPKH, single hot wallet) ──────────────────
# mainnet | testnet | signet | regtest
BITCOIN_NETWORK=testnet
# Public Esplora endpoints (Blockstream): mainnet → https://blockstream.info/api,
# testnet → https://blockstream.info/testnet/api. Run your own electrs
# in production for reliability.
BITCOIN_ESPLORA_URL=https://blockstream.info/testnet/api
# WIF format private key (e.g. starts with `c...` for testnet,
# `K.../L...` for mainnet compressed).
TREASURY_BTC_PRIVATE_KEY_WIF=
# Optional — derived from the WIF (P2WPKH) if left empty.
TREASURY_BTC_ADDRESS=
# Floor for fee rate; bumps automatically when network is congested
# isn't implemented (operator can raise this manually).
BITCOIN_FEE_SATS_PER_VBYTE=2

# ─── Zcash treasury (transparent only, delegated to zcashd) ────────
# zcashd JSON-RPC endpoint. The node holds the treasury's transparent
# private key in its wallet.dat — this service only needs to call
# `sendtoaddress`. Mainnet and testnet share the same shape.
ZCASH_RPC_URL=
ZCASH_RPC_USER=
ZCASH_RPC_PASSWORD=
TREASURY_ZEC_ADDRESS=

# ─── Policy ────────────────────────────────────────────────────────
# For test rollout keep liquidity check off to avoid RPC flakiness
RAMP_ENABLE_TREASURY_LIQUIDITY_CHECK=false

# Temporary max buy cap: $10.00 (in cents)
RAMP_ONRAMP_MAX_USD_CENTS=1000

# Optional URL used by initialize-payment provider checkout redirect
RAMP_FRONTEND_CALLBACK_URL=
